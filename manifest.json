{
  "manifest_version": 3,
  "name": "Prompt Genius",
  "version": "3.0.0",
  "description": "Supercharge your AI prompts with one click. Works on any AI platform.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*",
        "https://www.poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://you.com/*",
        "https://www.you.com/*",
        "https://huggingface.co/chat/*",
        "https://labs.google/*",
        "https://aistudio.google.com/*",
        "https://deepseek.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://grok.x.ai/*",
        "https://groq.com/*",
        "https://www.groq.com/*",
        "https://together.ai/*",
        "https://www.together.ai/*",
        "https://fireworks.ai/*",
        "https://www.fireworks.ai/*",
        "https://cohere.com/*",
        "https://www.cohere.com/*",
        "https://replicate.com/*",
        "https://www.replicate.com/*",
        "https://typingmind.com/*",
        "https://www.typingmind.com/*",
        "https://character.ai/*",
        "https://www.character.ai/*",
        "https://lmsys.org/*",
        "https://chat.lmsys.org/*",
        "https://ollama.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
